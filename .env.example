# LLM provider: "anthropic" or "openai_compatible"
AI_PROVIDER=anthropic
# Base URL only; client appends /v1/messages or /chat/completions
AI_BASE_URL=https://api.anthropic.com
# API key for the selected provider or compatible gateway
AI_API_KEY=sk-...
# Model name sent to the selected provider
AI_MODEL=claude-sonnet-4-6
