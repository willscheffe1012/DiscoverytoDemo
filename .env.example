# LLM provider: "anthropic" or "openai_compatible"
AI_PROVIDER=anthropic
# Base URL only; client appends /v1/messages or /chat/completions
AI_BASE_URL=https://api.anthropic.com
# API key for the selected provider or compatible gateway
AI_API_KEY=sk-...
# Model name sent to the selected provider
AI_MODEL=claude-sonnet-4-6
# Optional Anthropic auth header name for corporate gateways; default x-api-key.
# If set to Authorization, the client sends Authorization: Bearer ${AI_API_KEY}.
AI_AUTH_HEADER=x-api-key
# Optional JSON object merged into every AI request for either provider.
AI_EXTRA_HEADERS={}
